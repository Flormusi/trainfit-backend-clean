{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": ".",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "typeRoots": [
      "./node_modules/@types",
      "./src/types",
      "./src/types/express"
    ]
  },
  "include": [
    "src/**/*",
    "middleware/**/*",
    "models/**/*",
    "controllers/**/*",
    "routes/**/*",
    "server.ts",
    "prisma/**/*",
    "src/types/**/*" // <--- LÍNEA AGREGADA
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/legacy/**/*",
    "src/controllers/calendarController.ts",
    "src/services/calendarService.ts",
    "src/services/icsService.ts",
    "src/services/whatsappService.ts",
    "src/middleware/emailValidation.middleware.ts",
    "src/scripts/**/*"
  ]
}